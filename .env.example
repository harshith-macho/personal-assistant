# Copy this file to ~/.env and fill in your values
# chmod 600 ~/.env

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # Your personal chat ID (get from @userinfobot)
TELEGRAM_GROUP_ID=         # Group chat ID (negative number, e.g. -1001234567890)

# Telegram Topic Thread IDs (only needed if using group topics/forum mode)
TELEGRAM_TOPIC_CHAT=       # thread_id for "Chat" topic
TELEGRAM_TOPIC_EMAILS=     # thread_id for "Emails" topic
TELEGRAM_TOPIC_JOBS=       # thread_id for "Jobs" topic
TELEGRAM_TOPIC_STOCKS=     # thread_id for "Stocks" topic
TELEGRAM_TOPIC_DAILY=      # thread_id for "Daily" topic

# Gmail (use an App Password, not your real password)
# Enable at: myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=

# LinkedIn (used by Playwright for Easy Apply automation)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_URL=https://www.linkedin.com/in/your-profile   # your public LinkedIn URL

# Applicant profile — used by form_filler.py to auto-fill Easy Apply fields
PHONE_NUMBER=+353xxxxxxxxx
APPLICANT_CITY=Dublin
APPLICANT_COUNTRY=Ireland
SALARY_EXPECTATION=50000          # EUR per year
NOTICE_PERIOD=2 weeks
REQUIRE_SPONSORSHIP=no             # Set to "yes" when Stamp 1G expires (~2 years)
YEARS_EXP_TOTAL=2
YEARS_EXP_PYTHON=2
YEARS_EXP_AWS=1
YEARS_EXP_DOTNET=2
GITHUB_URL=                        # optional
WEBSITE_URL=                       # optional
